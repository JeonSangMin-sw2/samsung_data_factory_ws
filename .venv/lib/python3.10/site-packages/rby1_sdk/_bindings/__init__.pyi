        ...     print(f"Robot model: {robot.model().model_name}")
        ...     # Note: Model A has mobile base (2-DOF) + torso (6-DOF) + right arm (7-DOF) + left arm (7-DOF) + head (2-DOF)
        ...     # Total joints: 2 + 6 + 7 + 7 + 2 = 24 DOF for model A
