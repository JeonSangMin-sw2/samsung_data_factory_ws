    ...   .set_stiffness(np.full(7, 50.0))          # Nm/rad
    ...   .set_damping_ratio(0.7)                   # ζ
    ...   .set_torque_limit(np.full(7, 60.0))       # Nm
    ...   .set_velocity_limit(np.full(7, np.pi))    # rad/s
    ...   .set_acceleration_limit(np.full(7, 2.0))  # rad/s²
    ...   .set_minimum_time(1.0)                    # s
