            Self reference for method chaining.
        """
    def set_joint_torque_limit(self, torque_limit: numpy.ndarray[tuple[M, typing.Literal[1]], numpy.dtype[numpy.float64]]) -> CartesianImpedanceControlCommandBuilder:
